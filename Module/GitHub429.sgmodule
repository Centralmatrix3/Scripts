[Header Rewrite]
http-request ^https:\/\/(github\.com|(avatars|gist|raw)\.githubusercontent\.com)\/ header-replace Accept-Language en-us

[MITM]
hostname = %APPEND% gist.githubusercontent.com, raw.githubusercontent.com // github.com, avatars.githubusercontent.com